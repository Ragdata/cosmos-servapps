{
    "cosmos-installer": {},
    "minVersion": "0.9.0",
    "services": {
        "{ServiceName}": {
            "image": "stalwartlabs/mail-server:latest",
            "container_name": "{ServiceName}",
            "restart": "unless-stopped",
            "hostname": "mail-server",
            "tty": true,
            "stdin_open": true,
            "ports": [
              "443:443",
              "8080:8080",
              "25:25",
              "587:587",
              "465:465",
              "143:143",
              "993:993",
              "4190:4190",
              "110:110",
              "995:995"
            ],
            "network_mode": "cosmos-mail-server-default",
            "networks": {
                "cosmos-mail-server-default": {}
            },
            "labels": {
                "cosmos-force-network-secured": "true",
                "cosmos-auto-update": "true",
                "cosmos-icon": "https://raw.githubusercontent.com/Ragdata/cosmos-servapps/master/servapps/stalwart-mail/icon.png"
            },
            "volumes": [
                {
                  "source": "/mnt/vol/stalwart",
                  "target": "/opt/stalwart-mail",
                  "type": "bind"
                }
            ],
            "routes": [{
                "name": "{ServiceName}",
                "description": "Expose {ServiceName} to the web",
                "useHost": true,
                "target": "http://{ServiceName}:8080",
                "mode": "SERVAPP",
                "Timeout": 14400000,
                "ThrottlePerMinute": 12000,
                "BlockCommonBots": true,
                "SmartShield": {
                    "Enabled": true
                }
            }]
        }
    }
}
